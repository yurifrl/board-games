# --- Stateless auth ---
# Secret used to sign session cookies (HMAC-SHA256). Generate: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-32-byte-random-hex

# Public base URL (cookie is marked Secure automatically when this is https://). No trailing slash.
BASE_URL=http://localhost:3000

# Session lifetime in days.
SESSION_TTL_DAYS=7

# Temp users: the role preselected in the admin invite form (must be a non-admin
# role from whitelist.json). Invite links do not expire; access is governed by
# the JSONL store below.
DEFAULT_INVITE_ROLE=buyer

# --- Data (all baked into the image by default; override only if needed) ---
# Folder of board-game .md notes (defaults to the baked /app/inventory).
INVENTORY_DIR=/app/inventory

# Role config (YAML): roles -> capabilities + defaultRole. Non-secret; in k8s
# this is a ConfigMap. Baked default at /app/whitelist-config.yaml.
WHITELIST_CONFIG_PATH=/app/whitelist-config.yaml

# Users secret blob (one line per user: role:identifier=password). NOT baked;
# mount as a Secret. Missing -> no permanent logins (temp invites still work).
WHITELIST_USERS_PATH=/secrets/users

# Append-only JSONL temp-user db. Needs a WRITABLE path; mount a volume at /data
# to persist temp users across restarts.
TMP_USERS_PATH=/data/tmp-users.jsonl

# --- Bidding ---
# Your WhatsApp number in international format, digits only (e.g. 5511999998888).
WHATSAPP_NUMBER=5511999998888

PORT=3000
