# --- Stateless auth ---
# Secret used to sign session cookies (HMAC-SHA256). Generate: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-32-byte-random-hex

# Public base URL (cookie is marked Secure automatically when this is https://). No trailing slash.
BASE_URL=http://localhost:3000

# Session lifetime in days.
SESSION_TTL_DAYS=7

# Temp users: the role preselected in the admin invite form (must be a non-admin
# role from users.md). Invite links do not expire; access is governed by the
# JSONL store below.
DEFAULT_INVITE_ROLE=buyer

# --- Data (single volume) ---
# All state lives here: catalog.json, users.json, covers/, tmp-users.jsonl.
# The worker syncs catalog + users from Obsidian; the app reads from here only.
DATA_DIR=/data

# --- Worker (sidecar) ---
# Obsidian Local REST API (self-signed cert; TLS bypass is worker-only).
OBSIDIAN_API_URL=https://host.docker.internal:27124
OBSIDIAN_API_KEY=
OBSIDIAN_INVENTORY_FOLDER=Yuri/Resources/Board Games/Inventory
OBSIDIAN_USERS_NOTE=Yuri/Resources/Board Games/Users.md
SYNC_INTERVAL_MS=300000

# --- Play / scheduling (Google Calendar is the source of truth; read + write) ---
# The owner drops availability "block" events on this calendar; members pick a
# block for a game and the app writes the booked session back to the calendar.
# Needs a SERVICE ACCOUNT (reuse the GCS one) with the Calendar API enabled and
# this calendar shared to its email as "Make changes to events".
#   GOOGLE_APPLICATION_CREDENTIALS -> service-account JSON path (already set for GCS),
#   or GOOGLE_SA_JSON -> the JSON inline.
# Calendar ID: Calendar settings -> "Integrate calendar" -> Calendar ID.
GOOGLE_CALENDAR_ID=

# --- Google Sign-In (passwordless login for players) ---
# Create an OAuth 2.0 Client (type: Web) in Google Cloud Console. Authorized
# redirect URI must be exactly: <BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Hermes notify (owner gets a phone ping on each access request, no LLM) ---
# The board-games app POSTs (HMAC-signed) to a Hermes `deliver_only` webhook
# route. In-cluster URL, or unset to just log locally.
HERMES_WEBHOOK_URL=http://hermes.hermes.svc.cluster.local:8644/webhooks/login-alert
# Must match the route's `secret` in the Hermes config.
HERMES_WEBHOOK_SECRET=
# Flood guard: at most one owner ping per this many ms (default 60000).
HERMES_NOTIFY_THROTTLE_MS=60000

# --- Bidding ---
# Your WhatsApp number in international format, digits only (e.g. 5511999998888).
WHATSAPP_NUMBER=5511999998888

PORT=3000

# --- Assets API (covers + rulebooks, backed by private GCS) ---
# When ASSETS_GCS_BUCKET is set, GCS is the durable origin and the worker uploads
# there; unset = local-disk only (dev works with no GCS). Cover URL signing uses
# AUTH_SECRET by default (set ASSETS_SIGNING_SECRET to override).
ASSETS_GCS_BUCKET=
# Path to the GCS service-account key JSON (mounted from board-games-gcs-creds).
GOOGLE_APPLICATION_CREDENTIALS=
# Shared bearer token: Hermes uses it to POST /ingest rulebooks; AI agents use it
# to read /agent/... . Unset = ingest + agent endpoints are closed.
ASSET_TOKEN=
