# --- Stateless auth ---
# Secret used to sign session cookies (HMAC-SHA256). Generate: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-32-byte-random-hex

# Public base URL (cookie is marked Secure automatically when this is https://). No trailing slash.
BASE_URL=http://localhost:3000

# Session lifetime in days.
SESSION_TTL_DAYS=7

# Temp users: the role preselected in the admin invite form (must be a non-admin
# role from users.md). Invite links do not expire; access is governed by the
# JSONL store below.
DEFAULT_INVITE_ROLE=buyer

# --- Data (single volume) ---
# All state lives here: catalog.json, users.json, covers/, tmp-users.jsonl.
# The worker syncs catalog + users from Obsidian; the app reads from here only.
DATA_DIR=/data

# --- Worker (sidecar) ---
# Obsidian Local REST API (self-signed cert; TLS bypass is worker-only).
OBSIDIAN_API_URL=https://host.docker.internal:27124
OBSIDIAN_API_KEY=
OBSIDIAN_INVENTORY_FOLDER=Yuri/Resources/Board Games/Inventory
OBSIDIAN_USERS_NOTE=Yuri/Resources/Board Games/Users.md
SYNC_INTERVAL_MS=300000

# --- Bidding ---
# Your WhatsApp number in international format, digits only (e.g. 5511999998888).
WHATSAPP_NUMBER=5511999998888

PORT=3000

# --- Assets API (image aggregator backed by private GCS) ---
# When ASSETS_GCS_BUCKET is set, the app serves signed /assets/<id> URLs and the
# worker uploads cover originals to the bucket. Leave unset to keep serving the
# legacy /covers FS cache (local dev).
ASSETS_GCS_BUCKET=
# Secret for signing asset URLs (openssl rand -hex 32).
ASSETS_SIGNING_SECRET=
# Path to the GCS service-account key JSON (mounted from board-games-gcs-creds).
GOOGLE_APPLICATION_CREDENTIALS=
